# Server Configuration
PORT=3001
HOST=0.0.0.0
UPLOAD_DIR=./uploads

# Security
CORS_ORIGINS=https://localhost:5173,http://localhost:5173,http://127.0.0.1:5173
# API_KEY=change-me
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# Whisper (Speech-to-Text) Configuration
WHISPER_MODEL_PATH=large-v3
WHISPER_LANGUAGE=ru
WHISPER_DEVICE=cuda
WHISPER_PYTHON=python
WHISPER_COMPUTE_TYPE=float16
WHISPER_BEAM_SIZE=1
WHISPER_DEVICE_INDEX=0
WHISPER_CPU_COMPUTE_TYPE=int8
ALLOW_MOCK_TRANSCRIPTION=false

# LLM (llama.cpp) Configuration
LLM_SERVER_URL=http://localhost:8080
# Optional: used only when NODE_ENV=production and LLM_SERVER_URL is empty
# Example for LAN: http://192.168.1.50:8080
LLM_SERVER_URL_PROD=
LLM_MODEL=qwen3-8b
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.1
LLM_PARALLEL_SLOTS=1
LLM_TIMEOUT_MS=120000
ALLOW_MOCK_LLM=false
