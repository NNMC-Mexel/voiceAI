PORT=3001
HOST=0.0.0.0
UPLOAD_DIR=./uploads

CORS_ORIGINS=https://localhost:5173,http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

WHISPER_MODEL_PATH=large-v3
WHISPER_LANGUAGE=ru
WHISPER_DEVICE=cuda
WHISPER_PYTHON=
WHISPER_COMPUTE_TYPE=float16
WHISPER_BATCH_SIZE=16
WHISPER_BEAM_SIZE=1
# Детектор подозрительных чанков: в chunk_details появляются поля
# `suspicious` (список причин), `fallback_used`, `selected_beam`. Причины:
# low-logprob, АД без X/Y, посев без организма, мусорные единицы,
# phrase-loops. Всегда включён — сигнал пригоден для UX-warning на фронте.
#
# Beam-retry (WHISPER_MAX_FALLBACK_CHUNKS>0): на suspicious чанках повторно
# распознаёт с WHISPER_FALLBACK_BEAM_SIZE, winner — по clinical quality_score.
# Эмпирически не выигрывает у beam=1 на Whisper-артефактах единиц («165 сотых»,
# «гэслчэль», «коэслч»). По-умолчанию выключен (=0).
WHISPER_FALLBACK_BEAM_SIZE=5
WHISPER_SUSPICIOUS_LOGPROB=-0.95
WHISPER_MAX_FALLBACK_CHUNKS=0
WHISPER_DEVICE_INDEX=0
WHISPER_CPU_COMPUTE_TYPE=int8
ALLOW_MOCK_TRANSCRIPTION=false

LLM_SERVER_URL=http://localhost:8080
LLM_MODEL=qwen3-8b
LLM_MAX_TOKENS=256
LLM_TEMPERATURE=0.1
LLM_PARALLEL_SLOTS=1
LLM_TIMEOUT_MS=120000
ALLOW_MOCK_LLM=false

TTS_SERVER_URL=http://localhost:5500
TTS_ENABLED=true

AUTH_PASSWORD=

# PHI-дамп (raw Whisper + JSON документа) в temp/structure-logs/.
# Содержит медданные пациентов — оставлять отключённым в проде.
STRUCTURE_LOG_DUMP=false

# ВАЖНО: на проде секреты (ANTHROPIC_API_KEY, AUTH_PASSWORD) не хранить в .env.
# Использовать секрет-менеджер (AWS Secrets Manager / Vault / Doppler / 1Password).
# .env только для локальной разработки.
